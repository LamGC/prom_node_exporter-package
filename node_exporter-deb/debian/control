Source: prometheus-node-exporter
Section: net
Priority: optional
Maintainer: prom_node_exporter package maintainer <package@example.com>
Build-Depends: debhelper-compat (= 13)
Standards-Version: 4.7.0
Rules-Requires-Root: no

Package: prometheus-node-exporter
Architecture: any
Pre-Depends: ${misc:Pre-Depends}
Depends: adduser, logrotate, ${misc:Depends}
Description: Prometheus exporter for machine metrics
 Prometheus is a systems and service monitoring system. It collects
 metrics from configured targets at given intervals, evaluates rule
 expressions, displays the results, and can trigger alerts.
 .
 This package contains the node_exporter binary to export machine
 metrics to Prometheus.
 .
 Installed paths:
  - Binary: /usr/bin/node_exporter
  - Service: /lib/systemd/system/prometheus-node-exporter.service
  - Config: /etc/default/prometheus-node-exporter
  - Logrotate: /etc/logrotate.d/prometheus-node-exporter
